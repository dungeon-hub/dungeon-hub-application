<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <ExceptionAppender name="ExceptionAppender" />

        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout charset="UTF-8">
                <pattern>[%d{dd.MM.yyyy HH:mm:ss}] %-5level> %msg%n</pattern>
            </PatternLayout>
        </Console>

        <Routing name="Routing">
            <Routes pattern="$${sys:user.home}">
                <Route>
                    <File name="File" fileName="${sys:user.home}/carrylogs/logs/application/${date:yyyy_MM_dd-HH_mm_ss}.txt"
                          immediateFlush="false" append="false">
                        <PatternLayout charset="UTF-8">
                            <pattern>[%d{dd.MM.yyyy HH:mm:ss}] %-5level> %msg%n</pattern>
                        </PatternLayout>
                    </File>
                </Route>
            </Routes>
        </Routing>
    </Appenders>

    <Loggers>
        <Root level="debug">
            <AppenderRef ref="Console" level="info"/>
            <AppenderRef ref="Routing" level="debug"/>
            <AppenderRef ref="ExceptionAppender" level="error"/>
        </Root>
    </Loggers>
</Configuration>